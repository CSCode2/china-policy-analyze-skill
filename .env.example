# China Policy Intelligence Skill - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED - Core functionality will not work without these
# =============================================================================

# GitHub token for repository operations (PR creation, issue tracking, source registry)
GITHUB_TOKEN=

# OpenAI API key for LLM-based analysis (policy interpretation, distillation, evaluation)
OPENAI_API_KEY=

# OpenAI API base URL (use custom endpoint if needed, e.g., Azure OpenAI)
OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# REQUIRED - LLM Model Configuration
# =============================================================================

# Model to use for primary analysis tasks
OPENAI_MODEL=gpt-4o

# Model to use for lighter tasks (classification, extraction)
OPENAI_LIGHT_MODEL=gpt-4o-mini

# =============================================================================
# OPTIONAL - Data Storage
# =============================================================================

# Root directory for content cache
CONTENT_CACHE_DIR=./cache/content

# Root directory for index data
INDEX_DIR=./cache/index

# Root directory for document relationship graph
GRAPH_DIR=./cache/graph

# Root directory for phrase occurrence index
PHRASE_INDEX_DIR=./cache/phrases

# Root directory for forecasts and calibration data
FORECAST_DIR=./cache/forecasts

# Root directory for error and incident tracking
INCIDENT_DIR=./cache/incidents

# Root directory for quality metrics
METRICS_DIR=./cache/metrics

# Root directory for question bank
QUESTION_BANK_DIR=./cache/questions

# =============================================================================
# OPTIONAL - Crawler Configuration
# =============================================================================

# Maximum concurrent crawl requests
CRAWLER_MAX_CONCURRENT=2

# Default requests per minute
CRAWLER_RPM=15

# Default delay between requests in milliseconds
CRAWLER_DELAY_MS=2000

# Enable robots.txt compliance (recommended: true)
CRAWLER_RESPECT_ROBOTS=true

# User agent string (override default if needed)
CRAWLER_USER_AGENT=

# Proxy URL for crawling (useful for accessing sources from outside China)
CRAWLER_PROXY_URL=

# Proxy authentication
CRAWLER_PROXY_USERNAME=
CRAWLER_PROXY_PASSWORD=

# =============================================================================
# OPTIONAL - External API Keys
# =============================================================================

# News API for supplementary source checking
NEWS_API_KEY=

# FAO (Food and Agriculture Organization) API for agricultural data
FAO_API_KEY=

# World Bank API key (if required for enhanced access)
WORLD_BANK_API_KEY=

# SIPRI API key for military expenditure data
SIPRI_API_KEY=

# =============================================================================
# OPTIONAL - Notification and Alerting
# =============================================================================

# Slack webhook URL for alerts and daily briefings
SLACK_WEBHOOK_URL=

# Email notification settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Telegram bot token for alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# OPTIONAL - Hermes Agent Configuration
# =============================================================================

# Enable automatic self-merge for eligible PRs
HERMES_AUTO_MERGE=true

# Maximum time to wait before merging a PR (hours)
HERMES_MERGE_TIMEOUT_HOURS=48

# Enable automatic source URL update
HERMES_AUTO_FIX_URLS=true

# Enable automatic parser update for simple structure changes
HERMES_AUTO_FIX_PARSERS=true

# Maximum automatic parser fixes per day
HERMES_MAX_AUTO_FIXES_PER_DAY=5

# Escalation email for issues requiring human intervention
HERMES_ESCALATION_EMAIL=

# =============================================================================
# OPTIONAL - Quality and Safety Thresholds
# =============================================================================

# Minimum Brier score threshold (trigger investigation if exceeded)
CALIBRATION_BRIER_THRESHOLD=0.25

# Minimum answer quality score (trigger investigation if below)
QUALITY_SCORE_MIN=3.5

# Maximum hallucination rate per 100 answers
HALLUCINATION_RATE_MAX=0

# Maximum overinterpretation warning rate per 100 answers
OVERINTERPRETATION_RATE_MAX=5

# Source availability minimum percentage
SOURCE_AVAILABILITY_MIN=95

# Data freshness minimum percentage
DATA_FRESHNESS_MIN=90

# Maximum crawl error rate percentage
CRAWL_ERROR_RATE_MAX=5

# =============================================================================
# OPTIONAL - Geopolitical Risk Configuration
# =============================================================================

# Enable geopolitical risk monitoring
GEO_RISK_MONITORING_ENABLED=true

# Risk level threshold for escalation alerts (low/moderate/elevated/high/critical)
GEO_RISK_ALERT_THRESHOLD=elevated

# Enable economic impact tracking for geopolitical events
GEO_ECONOMIC_IMPACT_TRACKING=true

# =============================================================================
# OPTIONAL - Logging and Debugging
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable structured JSON logging
LOG_STRUCTURED=true

# Log file path (leave empty for stdout only)
LOG_FILE=

# Enable verbose crawl logging
CRAWL_VERBOSE_LOGGING=false

# Retention period for logs in days
LOG_RETENTION_DAYS=90

# =============================================================================
# OPTIONAL - Development
# =============================================================================

# Enable development mode (disables some safety features - DO NOT USE IN PRODUCTION)
DEV_MODE=false

# Dry run mode for Hermes (logs actions without executing)
HERMES_DRY_RUN=false
