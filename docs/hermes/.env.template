# Hermes Agent Environment Configuration
# COPY this to /root/.hermes/.env and FILL IN the values below.
# Ask the user for these credentials — DO NOT guess or hardcode them.

# OpenRouter API key (required)
# Get from https://openrouter.ai/keys
# Format: sk-or-v1-...
OPENAI_API_KEY=<ASK_USER_FOR_OPENROUTER_API_KEY>

# OpenRouter base URL
OPENAI_BASE_URL=https://openrouter.ai/api/v1